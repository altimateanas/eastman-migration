# =============================================================================
# Eastman Migration — Environment Configuration Template
# =============================================================================
# Copy this file to .env and fill in real values.
# .env is gitignored — this file is safe to commit.
# =============================================================================

# -----------------------------------------------------------------------------
# MS SQL Server (Source — Azure VM)
# -----------------------------------------------------------------------------
MSSQL_HOST=<public_ip>
MSSQL_PORT=1433
MSSQL_DATABASE=RetailDW
MSSQL_USER=<username>
MSSQL_PASSWORD=<password>
MSSQL_DRIVER=ODBC Driver 17 for SQL Server

# Connection string (for tools that prefer a single URI)
MSSQL_CONNECTION_STRING=mssql+pyodbc://<user>:<password>@<host>:1433/RetailDW?driver=ODBC+Driver+17+for+SQL+Server&TrustServerCertificate=yes

# -----------------------------------------------------------------------------
# Microsoft Fabric Data Warehouse (Target)
# -----------------------------------------------------------------------------
FABRIC_SERVER=<fabric_server_fqdn>
FABRIC_PORT=1433
FABRIC_DATABASE=migration
FABRIC_SCHEMA=dbo
FABRIC_DRIVER=ODBC Driver 17 for SQL Server
FABRIC_AUTHENTICATION=CLI
FABRIC_ENCRYPT=true
FABRIC_TRUST_CERT=false

# NOTE: ODBC Driver 17 does not support ActiveDirectoryDefault/AzCli keywords.
# Authentication is done by fetching an Azure AD access token via `az account get-access-token`
# and passing it as SQL_COPT_SS_ACCESS_TOKEN (see scripts/connect_fabric.py for helper).
# Connection string base (token injected at runtime):
FABRIC_CONNECTION_STRING=mssql+pyodbc://@<fabric_server_fqdn>:1433/migration?driver=ODBC+Driver+17+for+SQL+Server&Encrypt=yes&TrustServerCertificate=no
